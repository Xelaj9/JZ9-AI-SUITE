# ════════════════════════════════════════════════════════════════
#  JZ9suite — environment variables
# ════════════════════════════════════════════════════════════════
# Server-side ONLY (set these in Vercel → Project → Settings → Environment Variables).
# Never commit real values; never expose these in the browser.

# Existing — OpenAI proxy (api/proxy.js)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role — used only by privileged serverless functions
# (e.g. api/admin.js for role changes). NEVER ship to the client.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx_service_role_secret

# ----------------------------------------------------------------
# Public client values do NOT go here. They live in:
#   assets/js/config.js  (SUPABASE_URL + SUPABASE_ANON_KEY)
# The anon key is safe to expose because Row Level Security guards all data.

# ----------------------------------------------------------------
# Video Watermark Remover (api/video-watermark.js → Replicate / ProPainter)
# Server-side only.
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxx
# Paste the ProPainter model VERSION hash from its Replicate page:
REPLICATE_VERSION=
# (alternative to a version hash) official model slug, e.g. owner/propainter
# REPLICATE_MODEL=

# ----------------------------------------------------------------
# Image Tools (api/image-tools.js → Replicate) — uses the same
# REPLICATE_API_TOKEN above. Default models are built in:
#   removebg → 851-labs/background-remover
#   upscale  → nightmareai/real-esrgan
#   eraser   → allenhooo/lama
# Optional overrides (model slug or pinned version hash):
# REPLICATE_MODEL_REMOVEBG=
# REPLICATE_VERSION_REMOVEBG=
# REPLICATE_MODEL_UPSCALE=
# REPLICATE_VERSION_UPSCALE=
# REPLICATE_MODEL_ERASER=
# REPLICATE_VERSION_ERASER=
#   restore  → microsoft/bringing-old-photos-back-to-life
#   colorize → arielreplicate/deoldify_image
# REPLICATE_MODEL_RESTORE=
# REPLICATE_VERSION_RESTORE=
# REPLICATE_MODEL_COLORIZE=
# REPLICATE_VERSION_COLORIZE=
